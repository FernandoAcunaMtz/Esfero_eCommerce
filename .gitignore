# ============================================================
# ESFERO — .gitignore
# ============================================================

# ------------------------------------------------------------
# SECRETOS Y CREDENCIALES (NUNCA subir)
# ------------------------------------------------------------
.env
.env.local
.env.*.local
# .env.example SÍ debe subirse (sin valores reales)

# Claves JWT / RSA / certificados
backend/keys/
frontend/keys/
certs/
*.pem
*.key
*.p12
*.pfx

# Credenciales de servicios externos (PayPal, etc.)
Documentación/CREDENCIALES_*.txt
Documentación/CREDENCIALES_*.md

# ------------------------------------------------------------
# ARCHIVOS DE SEGURIDAD CRÍTICA (exponen info del servidor)
# ------------------------------------------------------------
frontend/info_servidor.php
# frontend/assets/db_direct.php
frontend/ver_logs.php
frontend/config_log.php
frontend/detectar_log.php

# ------------------------------------------------------------
# ARCHIVOS DE DEBUG Y TESTING (no van en producción)
# ------------------------------------------------------------
frontend/debug_*.php
frontend/test_*.php
frontend/diagnostico*.php
frontend/ver_error*.php
backend/cgi-bin/test_*.py

# ------------------------------------------------------------
# SCRIPTS DE DESARROLLO (seeders, migraciones locales)
# ------------------------------------------------------------
# scripts/seed_*.php  — habilitado para Railway deploy
scripts/reemplazar_*.php
scripts/ver_logs*.php
scripts/asignar_*.php

# ------------------------------------------------------------
# CONTENIDO GENERADO POR USUARIOS
# ------------------------------------------------------------
frontend/uploads/
!frontend/uploads/.gitkeep

# ------------------------------------------------------------
# LOGS
# ------------------------------------------------------------
*.log
logs/
frontend/logs/

# ------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
env/
venv/
ENV/
.venv/

# ------------------------------------------------------------
# PHP / COMPOSER
# ------------------------------------------------------------
/vendor/
composer.lock

# ------------------------------------------------------------
# NODE (si se usa npm/vite en el futuro)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# IDEs Y EDITORES
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.cursor/

# ------------------------------------------------------------
# SISTEMA OPERATIVO
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ------------------------------------------------------------
# ARCHIVOS TEMPORALES Y BACKUPS
# ------------------------------------------------------------
*.tmp
*.temp
~*
*.bak
*.backup
