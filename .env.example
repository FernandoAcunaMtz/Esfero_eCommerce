# ============================================================
# ESFERO MARKETPLACE — Variables de Entorno
# ============================================================

# -------------------------------------------------------
# BASE DE DATOS (MySQL)
# -------------------------------------------------------
DB_HOST=db
DB_NAME=esfero
DB_USER=esfero_user
DB_PASSWORD=esfero_pass
DB_PORT=3306
DB_CHARSET=utf8mb4

# -------------------------------------------------------
# PAYPAL
# Obtén tus keys en developer.paypal.com
# Para desarrollo usa modo sandbox
# -------------------------------------------------------
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=AeQmMsX61wEOaPyjxdv7ikGwPsBjhMgxMybkAclcpRUHttrmlALyNtgIIj1AQYI23NLyAOE6I34nuMAw
PAYPAL_CLIENT_SECRET=EJES9LgjH7rX63eoT8XLW0kZhT1fqE0kKxdnjIXViSzOsWcMXAAus37Ya0ZhmlmkTboVVqtUY62Q-EAj
PAYPAL_RETURN_URL=http://localhost:8080/checkout.php?success=true
PAYPAL_CANCEL_URL=http://localhost:8080/checkout.php?canceled=true
PAYPAL_CURRENCY=MXN

# -------------------------------------------------------
# JWT (claves RSA generadas automáticamente en Docker build)
# -------------------------------------------------------
JWT_PRIVATE_KEY=/var/www/esfero/backend/keys/jwt_private.pem
JWT_PUBLIC_KEY=/var/www/esfero/backend/keys/jwt_public.pem
JWT_EXPIRATION_HOURS=24

# -------------------------------------------------------
# APLICACIÓN
# -------------------------------------------------------
APP_NAME=Esfero Marketplace
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_SECRET=genera-una-cadena-aleatoria-segura-aqui

# -------------------------------------------------------
# API
# -------------------------------------------------------
API_BASE_URL=http://localhost/esfero/backend/cgi-bin
API_TIMEOUT=30
API_VERIFY_SSL=false

# -------------------------------------------------------
# SESIÓN
# -------------------------------------------------------
SESSION_LIFETIME=120

# -------------------------------------------------------
# CORREO (Mailtrap para desarrollo)
# Obtén tus credenciales en mailtrap.io → Sandboxes → My Sandbox → Integration
# -------------------------------------------------------
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=tu_mailtrap_username
MAIL_PASSWORD=tu_mailtrap_password
MAIL_FROM_ADDRESS=noreply@esfero.com
MAIL_FROM_NAME=Esfero Marketplace
