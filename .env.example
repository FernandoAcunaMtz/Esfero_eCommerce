# ============================================================
# ESFERO MARKETPLACE - Variables de Entorno
# Copia este archivo a .env y llena los valores reales
# NUNCA subas el .env real a GitHub
# ============================================================

# -------------------------------------------------------
# BASE DE DATOS (MySQL)
# -------------------------------------------------------
DB_HOST=localhost
DB_NAME=esfero
DB_USER=tu_usuario_db
DB_PASSWORD=tu_contraseña_db
DB_PORT=3306
DB_CHARSET=utf8mb4

# -------------------------------------------------------
# PAYPAL (obtén tus keys en developer.paypal.com)
# Para desarrollo usa el modo sandbox
# -------------------------------------------------------
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=tu_paypal_client_id
PAYPAL_CLIENT_SECRET=tu_paypal_client_secret
PAYPAL_RETURN_URL=http://localhost/esfero/frontend/checkout.php?success=true
PAYPAL_CANCEL_URL=http://localhost/esfero/frontend/checkout.php?canceled=true
PAYPAL_SANDBOX_URL=https://sandbox.paypal.com
PAYPAL_LIVE_URL=https://api.paypal.com
PAYPAL_CURRENCY=MXN

# -------------------------------------------------------
# JWT (claves RSA generadas localmente)
# Genera con: openssl genrsa -out backend/keys/jwt_private.pem 2048
#             openssl rsa -in backend/keys/jwt_private.pem -pubout -out backend/keys/jwt_public.pem
# -------------------------------------------------------
JWT_PRIVATE_KEY=backend/keys/jwt_private.pem
JWT_PUBLIC_KEY=backend/keys/jwt_public.pem
JWT_EXPIRATION_HOURS=24

# -------------------------------------------------------
# APLICACIÓN
# -------------------------------------------------------
APP_NAME=Esfero Marketplace
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost/esfero
APP_SECRET=genera-una-cadena-aleatoria-segura-aqui

# -------------------------------------------------------
# API
# -------------------------------------------------------
API_BASE_URL=http://localhost/esfero/backend/cgi-bin
API_TIMEOUT=30
API_VERIFY_SSL=true

# -------------------------------------------------------
# SESIÓN
# -------------------------------------------------------
SESSION_LIFETIME=120
